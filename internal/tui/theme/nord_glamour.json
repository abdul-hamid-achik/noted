{
  "document": { "block_prefix": "\n", "block_suffix": "\n", "color": "#d8dee9", "margin": 0 },
  "block_quote": { "color": "#81a1c1", "indent": 1, "indent_token": "│ " },
  "paragraph": {},
  "list": { "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#88c0d0", "bold": true },
  "h1": { "prefix": " ", "suffix": " ", "color": "#2e3440", "background_color": "#88c0d0", "bold": true },
  "h2": { "prefix": "## ", "color": "#8fbcbb" },
  "h3": { "prefix": "### ", "color": "#81a1c1" },
  "h4": { "prefix": "#### ", "color": "#81a1c1" },
  "h5": { "prefix": "##### ", "color": "#5e81ac" },
  "h6": { "prefix": "###### ", "color": "#5e81ac", "bold": false },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#ebcb8b", "italic": true },
  "strong": { "color": "#88c0d0", "bold": true },
  "hr": { "color": "#4c566a", "format": "\n--------\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#88c0d0", "underline": true },
  "link_text": { "color": "#8fbcbb", "bold": true },
  "image": { "color": "#b48ead", "underline": true },
  "image_text": { "color": "#d8dee9", "format": "Image: {{.text}} →" },
  "code": { "prefix": " ", "suffix": " ", "color": "#d08770", "background_color": "#3b4252" },
  "code_block": {
    "color": "#d8dee9",
    "margin": 0,
    "chroma": {
      "text": { "color": "#d8dee9" },
      "error": { "color": "#eceff4", "background_color": "#bf616a" },
      "comment": { "color": "#4c566a" },
      "comment_preproc": { "color": "#d08770" },
      "keyword": { "color": "#81a1c1" },
      "keyword_reserved": { "color": "#81a1c1" },
      "keyword_namespace": { "color": "#81a1c1" },
      "keyword_type": { "color": "#8fbcbb" },
      "operator": { "color": "#81a1c1" },
      "punctuation": { "color": "#eceff4" },
      "name": { "color": "#d8dee9" },
      "name_builtin": { "color": "#88c0d0" },
      "name_tag": { "color": "#81a1c1" },
      "name_attribute": { "color": "#8fbcbb" },
      "name_class": { "color": "#8fbcbb", "underline": true, "bold": true },
      "name_constant": { "color": "#b48ead" },
      "name_decorator": { "color": "#d08770" },
      "name_function": { "color": "#88c0d0" },
      "literal": { "color": "#b48ead" },
      "literal_number": { "color": "#b48ead" },
      "literal_string": { "color": "#a3be8c" },
      "literal_string_escape": { "color": "#a3be8c" },
      "generic_deleted": { "color": "#bf616a" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#a3be8c" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#4c566a" },
      "background": { "background_color": "#2e3440" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
